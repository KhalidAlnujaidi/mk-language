#!/usr/bin/env bash
# kin — the admin/core scope of kinox (vision §8.2, the "keyword jail").
#
# From anywhere on the machine, `kin` enters the governed admin scope at the
# kinox repo root (venv active, kx on PATH, KINOX_ADMIN=1) and launches a Claude
# Code session there:
#
#     kin            -> claude $KIN_CLAUDE_ARGS   (default: --dangerously-skip-permissions)
#     kin shell      -> a plain admin bash subshell instead (escape hatch)
#
# If `claude` is not found it falls back to the admin subshell. Override the
# launch flags with KIN_CLAUDE_ARGS (e.g. KIN_CLAUDE_ARGS="" for a bare claude).
# Non-interactive callers (no TTY: pipes / CI / tests) print the plan and exit,
# never launching or hanging.
#
# `kin` is reserved — it is the admin door, never a project name (`kx new kin`
# is jailed; `kx kin` hands off here).
set -uo pipefail

# Resolve our real location even when invoked via a PATH symlink
# (~/.local/bin/kin -> ~/kinox/kin), so "run it from anywhere" lands at the
# true repo root.
SOURCE="$(readlink -f "${BASH_SOURCE[0]}")"
REPO_DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
VENV="$REPO_DIR/.venv"
# The directory the session opens in. Defaults to the repo root (admin scope);
# `kx new`/`kx <project>` point it at a project dir via KIN_SCOPE_DIR.
SCOPE_DIR="${KIN_SCOPE_DIR:-$REPO_DIR}"
MODE="${1:-claude}"                                       # bare kin -> claude
# ${VAR-default} (no colon): default only when UNSET, so KIN_CLAUDE_ARGS="" wins.
KIN_CLAUDE_ARGS="${KIN_CLAUDE_ARGS---dangerously-skip-permissions}"

bold() { printf '\033[1m%s\033[0m\n' "$*"; }

# What this invocation will do (printed always; the non-interactive contract).
if [ "$MODE" = "shell" ] || [ "$MODE" = "sh" ]; then
  PLAN="admin shell"
else
  PLAN="launch Claude Code (claude ${KIN_CLAUDE_ARGS})"
fi

bold "==> kin · admin scope"
echo "    root:  $REPO_DIR"
echo "    scope: $SCOPE_DIR"
echo "    plan:  $PLAN"
[ -d "$VENV" ] || echo "    (no .venv — run '$REPO_DIR/install.sh' first)" >&2

# No TTY → report the plan and exit; never hang or launch an automated caller.
if [ ! -t 0 ]; then
  echo "    (non-interactive: not entering the admin scope)"
  exit 0
fi

# Drop into a plain interactive admin subshell rooted at the repo.
admin_subshell() {
  local rc
  rc="$(mktemp)"
  cat > "$rc" <<RCEOF
[ -f "\$HOME/.bashrc" ] && source "\$HOME/.bashrc"   # your normal shell first
[ -d "$VENV" ] && source "$VENV/bin/activate"        # then the kinox venv (wins)
export PATH="$REPO_DIR:\$PATH"                        # kx + kin + claude on PATH
export KINOX_HOME="$REPO_DIR"
export KINOX_ADMIN=1
cd "$SCOPE_DIR"
PS1="(kin·admin) \w \\\$ "
echo
echo "Admin scope. Tools: kx | claude | pytest -q | ruff check . | pyright | git"
echo "Type 'exit' to leave."
RCEOF
  bash --rcfile "$rc" -i || true
  rm -f "$rc"
}

# Activate the venv + repo env in THIS process, ready to exec claude into it.
# Opens in SCOPE_DIR (repo root for admin; the project dir for kx new/activate).
enter_env() {
  # shellcheck disable=SC1091
  [ -d "$VENV" ] && source "$VENV/bin/activate"
  export PATH="$REPO_DIR:$PATH"
  export KINOX_HOME="$REPO_DIR"
  export KINOX_ADMIN=1
  cd "$SCOPE_DIR" || exit 1
}

if [ "$MODE" = "shell" ] || [ "$MODE" = "sh" ]; then
  admin_subshell
elif enter_env && command -v claude >/dev/null 2>&1; then
  bold "==> launching Claude Code"
  # shellcheck disable=SC2086  # word-splitting KIN_CLAUDE_ARGS into flags is intended
  exec claude $KIN_CLAUDE_ARGS                            # replaces this process
else
  echo "    (claude not found — dropping into the admin shell instead)" >&2
  admin_subshell
fi

bold "==> left kin admin scope"
