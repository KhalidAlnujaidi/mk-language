#!/usr/bin/env bash
# kin — the admin/core scope of kinox (vision §8.2, the "keyword jail").
#
# From anywhere on the machine, `kin` drops you into an interactive admin
# subshell rooted at the kinox repo: the venv is active, `kx` is on PATH, and
# KINOX_ADMIN=1 marks the scope. `kin` is reserved — it is the admin door, never
# a project name (`kx new kin` is rejected; `kx kin` hands off here).
#
# Non-interactive invocation (no TTY: pipes, CI, tests) reports the resolved root
# and exits 0 rather than hanging on a subshell.
set -uo pipefail

# Resolve our real location even when invoked via a PATH symlink (~/.local/bin/kin
# -> ~/kinox/kin), so "run it from anywhere" lands at the true repo root.
SOURCE="$(readlink -f "${BASH_SOURCE[0]}")"
REPO_DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
VENV="$REPO_DIR/.venv"

bold() { printf '\033[1m%s\033[0m\n' "$*"; }

bold "==> kin · admin scope"
echo "    root: $REPO_DIR"
if [ ! -d "$VENV" ]; then
  echo "    (no .venv — run '$REPO_DIR/install.sh' first)" >&2
fi

# No TTY → report and exit; never hang an automated caller on an interactive shell.
if [ ! -t 0 ]; then
  echo "    (non-interactive: not entering the admin subshell)"
  exit 0
fi

# Interactive: drop into an admin subshell rooted at the repo.
RC="$(mktemp)"
cat > "$RC" <<RCEOF
[ -f "\$HOME/.bashrc" ] && source "\$HOME/.bashrc"   # your normal shell first
[ -d "$VENV" ] && source "$VENV/bin/activate"        # then the kinox venv (wins)
export PATH="$REPO_DIR:\$PATH"                        # kx + kin work everywhere
export KINOX_HOME="$REPO_DIR"
export KINOX_ADMIN=1
cd "$REPO_DIR"
PS1="(kin·admin) \w \\\$ "
echo
echo "Admin scope. Tools: kx | pytest -q | ruff check . | pyright | git"
echo "Type 'exit' to leave."
RCEOF

bash --rcfile "$RC" -i || true
rm -f "$RC"
bold "==> left kin admin scope"
