# Python
__pycache__/
*.py[cod]
.venv/
.pytest_cache/
.ruff_cache/
*.egg-info/

# uv
# (uv.lock IS committed — it's the hermetic lockfile)

# User projects live here but are not part of the repo (vision §8.4)
/projects/*
!/projects/.gitkeep

# Local working memory / session buffers
/.remember/

# OS / editor
.DS_Store
._*
*.swp
*.bak

# Runtime output / local dev logs (not part of the framework)
/var/
developer logs/

# Timestamped session / prompt captures (scratch, not framework)
/20[0-9][0-9]-[0-9][0-9]-[0-9][0-9]-*.txt

# Internal status reports (dev artifacts, not part of the framework)
/report*.md
**/session-report-*.md

# Stray scratch / vendored dumps (not part of the framework)
.deepseek/
.ts
cheatcodes/
first_sprint.txt

# temp dev-entry helper (not part of the repo)
enter.sh

# Ralph loop / session scaffolding (not framework)
RALPH_GOAL*.md
day1_dev.txt
gate-experiment-plan.md
.claude/ralph-loop.local.md

# Local secrets & user adapters
.env
/adapters/
