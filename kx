#!/usr/bin/env python3
"""kx — the kinox entrypoint (vision §8.2).

  kx                 → the launcher hub (the default working environment)
  kx doctor          → health check
  kx status          → observability dashboard
  kx new <project>   → scaffold a project under projects/<name>/, then enter it
  kx <project>       → activate an existing project (enter a Claude Code session)
  kx kin             → enter the admin scope at the repo root

Bare `kx` opens the hub: pick the admin scope / a project / an action, and it
runs, then you return to the hub. Naming a scope (`kx kin`, `kx <project>`)
skips the hub and execve's the `kin` launcher straight into Claude Code.
`kin` is the reserved admin/core scope — jailed as a project *name*
(`kx new kin` is rejected) but openable via `kx kin`.

Cold-start discipline: stdlib-only imports at module load; heavy imports
(rich/questionary/kernel/products) live inside the functions that use them.
"""

import os
import sys
from pathlib import Path

RESERVED = {"kin"}


def _ensure_venv() -> None:
    """Re-exec under the repo's venv interpreter so outer-layer deps import.

    Running ``kx`` cold (via the ~/.local/bin symlink) uses the system python,
    which lacks rich/questionary. If a ``.venv`` exists and we're not already in
    it, replace this process with the venv python running the same args. A no-op
    under tests (pytest already runs as the venv interpreter).
    """
    repo = Path(__file__).resolve().parent
    venv_py = repo / ".venv" / "bin" / "python3"
    if venv_py.exists() and Path(sys.executable).resolve() != venv_py.resolve():
        os.execv(str(venv_py), [str(venv_py), str(repo / "kx"), *sys.argv[1:]])


def _reject_reserved(name: str) -> None:
    if name in RESERVED:
        print(f"error: '{name}' is the reserved admin/core scope — not a project name.")
        sys.exit(2)


def hub(role: str | None = None) -> int:
    """The default working environment: the launcher hub (vision §8.2).

    Opens with a login layer (pick admin / developer) unless *role* is given,
    checks GitHub (fetch + notify), then lists the scopes + actions for that
    role. Launches claude by SPAWNING the ``kin`` script as a subprocess (so
    control returns when claude exits), unlike the direct shortcuts which execve.
    """
    from products.cli.commands import scaffold_project
    from products.launcher import sync
    from products.launcher.app import make_kin_spawner, run, select_role

    repo_root = Path(__file__).resolve().parent
    projects_dir = repo_root / "projects"
    is_tty = sys.stdin.isatty()

    # Login layer: explicit arg → inherited env → interactive pick → admin.
    if role is None:
        role = os.environ.get("KINOX_ROLE") or (select_role() if is_tty else "admin")

    # Startup sync: check origin only when interactive (no network in tests/pipes).
    if is_tty:
        print(sync.startup_status())

    spawn = make_kin_spawner(repo_root / "kin", role=role)

    def open_dashboard() -> None:
        status()

    def run_doctor() -> None:
        doctor()

    def new_project() -> "Path | None":
        name = input("new project name> ").strip()
        if not name:
            return None
        try:
            return scaffold_project(projects_dir, name)
        except ValueError as exc:  # reserved name (kin)
            print(f"  {exc}")
            return None

    return run(
        projects_dir=projects_dir,
        spawn=spawn,
        role=role,
        is_tty=is_tty,
        dashboard=open_dashboard,
        doctor=run_doctor,
        new_project=new_project,
    )


def update_cmd() -> int:
    """`kx update` — fetch origin and fast-forward when behind, clean, and safe."""
    from products.launcher import sync

    print(sync.update())
    return 0


def doctor() -> int:
    # Cold-start discipline: import kernel modules inside the function body.
    from kernel.manifest import probe

    m = probe()

    def _fmt(val: object) -> str:
        return str(val) if val is not None else "unknown"

    fitting = m.fitting_local_models()
    fitting_str = ", ".join(model.name for model in fitting) if fitting else "none"
    cloud_str = "yes" if m.cloud_available else "no"

    print("kx doctor — system health")
    print(f"  cpu:                  {_fmt(m.cpu_count)}")
    print(f"  ram (gb):             {_fmt(m.ram_gb)}")
    print(f"  gpu vram (gb):        {_fmt(m.gpu_vram_gb)}")
    print(f"  fitting local models: {fitting_str}")
    print(f"  cloud:                {cloud_str}")

    # Reconciliation: expected-vs-runtime drift (no persisted baseline yet, so
    # expected == present → healthy; protected-file checksums wire in later).
    from daemon.doctor import diagnose
    from products.cli.commands import format_doctor_findings

    present = {model.name for model in m.local_models}
    findings = diagnose(expected_models=present, present_models=present)
    print(format_doctor_findings(findings))
    return 0


def _enter(cwd: object, *, scope: str | None) -> int:
    """Launch a governed Claude Code session rooted at *cwd* (via the kin entry).

    Hands off to the ``kin`` script with ``KIN_SCOPE_DIR`` set, so every scope
    entry (admin, new project, activate) shares ONE launcher. ``scope=None`` is
    the admin scope (repo root). Replaces this process; does not return.
    """
    kin = Path(__file__).resolve().parent / "kin"
    env = dict(os.environ)
    if scope is not None:
        env["KIN_SCOPE_DIR"] = str(cwd)
    sys.stdout.flush()  # flush prints before execve replaces the process
    # "claude" mode = launch straight into Claude Code (bypass the hub). A named
    # scope means you want to be IN it, not back at the menu.
    os.execve(str(kin), [str(kin), "claude"], env)


def new(name: str) -> int:
    _reject_reserved(name)
    # Cold-start discipline: heavy imports inside the function body.
    from products.cli.commands import scaffold_project

    repo_root = Path(__file__).resolve().parent
    project = scaffold_project(repo_root / "projects", name)
    print(str(project / "next.md"))
    # Scaffolded → drop straight into a Claude Code session in the new project.
    return _enter(project, scope=name)


def status() -> int:
    # Cold-start discipline: heavy imports (rich) only on demand.
    from products.dashboard.app import build_summary, render
    from rich.console import Console

    metrics = Path.home() / ".kinox" / "broker-events.jsonl"
    if not metrics.exists():
        print(f"kx status: no metrics yet at {metrics}")
        return 0
    Console().print(render(build_summary(metrics)))
    return 0


def activate(name: str) -> int:
    repo_root = Path(__file__).resolve().parent
    if name in RESERVED:
        # `kin` is the admin/core scope, not a project — open the admin scope
        # (repo root) rather than rejecting. `kx new kin` is still jailed.
        return _enter(repo_root, scope=None)
    project = repo_root / "projects" / name
    if not project.is_dir():
        print(f"kx {name!r}: no such project — scaffold it with: kx new {name}")
        return 2
    # Activate an existing project → Claude Code session in its dir.
    return _enter(project, scope=name)


def main(argv: list[str]) -> int:
    if not argv:
        return hub()  # bare `kx` → the default working environment (the hub)
    cmd, *rest = argv
    if cmd == "doctor":
        return doctor()
    if cmd == "status":
        return status()
    if cmd == "update":
        return update_cmd()
    if cmd == "dev":
        return hub(role="developer")  # the hub as a developer (projects only)
    if cmd == "new":
        if not rest:
            print("usage: kx new <project>")
            return 2
        return new(rest[0])
    return activate(cmd)


if __name__ == "__main__":
    _ensure_venv()  # ensure outer-layer deps (rich/questionary) are importable
    raise SystemExit(main(sys.argv[1:]))
