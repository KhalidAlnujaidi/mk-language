#!/usr/bin/env python3
"""kx — the kinox entrypoint (vision §8.2).

  kx                 → the launcher hub (the default working environment)
  kx doctor          → health check
  kx status          → observability dashboard
  kx new <project>   → scaffold a project under projects/<name>/, then enter it
  kx <project>       → activate an existing project (enter its scope directly)
  kx kin             → enter the launcher hub as admin
  kx session         → launch a kinox chat session (called by `kin`)
  kx broker <cmd>    → control the broker daemon (status | start | stop)

Bare `kx` opens the hub: pick a role, a scope, or an action, and it runs, then
you return. Every `kx*` entry stays inside the hub — naming a scope (`kx kin`,
`kx <project>`, `kx new`) pre-selects it, spawns a fresh kinox session as a
SUBPROCESS, and falls back into the hub when that session exits (no execve, so
control always returns). The broker daemon is brought up lazily before the first
session so the groom pipeline's fuzzy tag step has a local model to call.
`kin` is the reserved admin/core scope — jailed as a project *name*
(`kx new kin` is rejected) but openable via `kx kin`.

Cold-start discipline: stdlib-only imports at module load; heavy imports
(rich/questionary/kernel/products) live inside the functions that use them.
"""

import os
import sys
from pathlib import Path

RESERVED = {"kin"}


def _load_env() -> None:
    """Load secrets from ``~/.kinox/env`` into the process environment.

    kinox reads keys from ``os.environ`` (e.g. ``ZAI_API_KEY`` for the cloud
    brain). This file lives under ``$HOME`` — outside the repo, never committed —
    so the brain works no matter which shell launched ``kx``. Format is plain
    ``KEY=value`` lines (``#`` comments and blanks ignored); existing env vars
    win, so an explicit ``export`` in the shell still overrides the file.
    Stdlib-only and silent on absence — kx cold-start discipline.
    """
    env_file = Path.home() / ".kinox" / "env"
    try:
        text = env_file.read_text(encoding="utf-8")
    except OSError:
        return
    for line in text.splitlines():
        line = line.strip()
        if not line or line.startswith("#") or "=" not in line:
            continue
        key, _, value = line.partition("=")
        key = key.strip()
        value = value.strip().strip('"').strip("'")
        if key and key not in os.environ:
            os.environ[key] = value


def _ensure_venv() -> None:
    """Re-exec under the repo's venv interpreter so outer-layer deps import.

    Running ``kx`` cold (via the ~/.local/bin symlink) uses the system python,
    which lacks rich/questionary. If a ``.venv`` exists and we're not already in
    it, replace this process with the venv python running the same args. A no-op
    under tests (pytest already runs as the venv interpreter).
    """
    repo = Path(__file__).resolve().parent
    venv_py = repo / ".venv" / "bin" / "python3"
    if venv_py.exists() and Path(sys.executable).resolve() != venv_py.resolve():
        os.execv(str(venv_py), [str(venv_py), str(repo / "kx"), *sys.argv[1:]])


def _reject_reserved(name: str) -> None:
    if name in RESERVED:
        print(f"error: '{name}' is the reserved admin/core scope — not a project name.")
        sys.exit(2)


def hub(role: str | None = None, *, preselect: "Path | None" = None) -> int:
    """The default working environment: the launcher hub (vision §8.2).

    Opens with a login layer (pick admin / developer) unless *role* is given,
    brings the broker up lazily, checks GitHub (fetch + notify), then lists the
    scopes + actions for that role. Sessions launch by SPAWNING the ``kin``
    script as a subprocess, so control returns to the hub when a session exits —
    there is no execve anywhere; the hub is the persistent container.

    *preselect* is the named-scope fast path: ``kx kin`` / ``kx <project>`` /
    ``kx new`` pass the scope dir here so it is spawned immediately, then the hub
    loop takes over on exit. With no TTY (tests / pipes / CI) the entry prints
    its plan and exits 0 without spawning — the existing non-interactive contract.
    """
    from products.cli.commands import scaffold_project
    from products.launcher import sync
    from products.launcher.app import make_kin_spawner, run, select_role

    repo_root = Path(__file__).resolve().parent
    projects_dir = repo_root / "projects"
    is_tty = sys.stdin.isatty()

    # Login layer: explicit arg → inherited env → interactive pick → admin.
    if role is None:
        role = os.environ.get("KINOX_ROLE") or (select_role() if is_tty else "admin")

    # Backbone + startup sync: only when interactive (no daemon/network in tests).
    if is_tty:
        # Bring the broker up lazily so the groom tag step has a local model to
        # call. Fail-soft (thesis #2): if it can't start, tagging falls back to
        # deterministic keywords. Verbose only for admin/developer roles.
        try:
            from daemon.launch import ensure_up

            broker = ensure_up()
            if role in ("admin", "developer"):
                print(f"  broker: {broker.reason} ({broker.socket})")
        except Exception:  # noqa: BLE001 — never let broker setup block the hub
            pass
        print(sync.startup_status())

    spawn = make_kin_spawner(repo_root / "kin", role=role)

    def open_dashboard() -> None:
        status()

    def run_doctor() -> None:
        doctor()

    def new_project() -> "Path | None":
        from products.launcher.app import import_questionary

        qmod = import_questionary()
        if qmod is not None:
            name = qmod.text("new project name:", qmark="▸").ask()
            if name is not None:
                name = name.strip()
        else:
            name = input("new project name> ").strip()
        if not name:
            return None
        try:
            return scaffold_project(projects_dir, name)
        except ValueError as exc:  # reserved name (kin)
            print(f"  {exc}")
            return None

    def run_chat() -> None:
        from kernel.manifest import probe
        from kernel.metrics import MetricsSink
        from products.chat.app import chat_run

        chat_run(
            manifest=probe(),
            sink=MetricsSink(Path.home() / ".kinox" / "chat-events.jsonl"),
            cwd=repo_root,
        )

    # Named-scope fast path: pre-select the scope, spawn a fresh session, then
    # fall into the hub loop so control returns here when it exits (no execve).
    if preselect is not None:
        print(
            f"==> kinox · enter scope: {preselect} — launch governed kinox chat session"
        )
        if not is_tty:
            return 0  # non-interactive: report the plan and leave; never spawn
        spawn(preselect)

    return run(
        projects_dir=projects_dir,
        spawn=spawn,
        role=role,
        is_tty=is_tty,
        dashboard=open_dashboard,
        doctor=run_doctor,
        chat=run_chat,
        new_project=new_project,
    )


def update_cmd() -> int:
    """`kx update` — fetch origin and fast-forward when behind, clean, and safe."""
    from products.launcher import sync

    print(sync.update())
    return 0


def doctor() -> int:
    # Cold-start discipline: import kernel modules inside the function body.
    from kernel.manifest import probe

    m = probe()

    def _fmt(val: object) -> str:
        return str(val) if val is not None else "unknown"

    fitting = m.fitting_local_models()
    fitting_str = ", ".join(model.name for model in fitting) if fitting else "none"
    cloud_str = "yes" if m.cloud_available else "no"

    print("kx doctor — system health")
    print(f"  cpu:                  {_fmt(m.cpu_count)}")
    print(f"  ram (gb):             {_fmt(m.ram_gb)}")
    print(f"  gpu vram (gb):        {_fmt(m.gpu_vram_gb)}")
    print(f"  fitting local models: {fitting_str}")
    print(f"  cloud:                {cloud_str}")

    # Reconciliation: expected-vs-runtime drift (no persisted baseline yet, so
    # expected == present → healthy; protected-file checksums wire in later).
    from daemon.doctor import diagnose
    from products.cli.commands import format_doctor_findings

    present = {model.name for model in m.local_models}
    findings = diagnose(expected_models=present, present_models=present)
    print(format_doctor_findings(findings))

    # Backbone health: is the broker daemon up? (vision §5.3, governed-TUI spec.)
    from daemon.launch import status_line

    print(f"  {status_line()}")
    return 0


def broker_cmd(rest: list[str]) -> int:
    """`kx broker {status|start|stop}` — drive the broker daemon explicitly."""
    from daemon.launch import ensure_up, status_line, stop

    sub = rest[0] if rest else "status"
    if sub == "status":
        print(f"kx {status_line()}")
        return 0
    if sub == "start":
        state = ensure_up()
        print(f"kx broker: {state.reason} ({state.socket})")
        return 0 if state.running else 1
    if sub == "stop":
        print(f"kx broker: {stop()}")
        return 0
    print("usage: kx broker {status|start|stop}")
    return 2


def new(name: str) -> int:
    _reject_reserved(name)
    # Cold-start discipline: heavy imports inside the function body.
    from products.cli.commands import scaffold_project

    repo_root = Path(__file__).resolve().parent
    project = scaffold_project(repo_root / "projects", name)
    print(str(project / "next.md"))
    # Scaffolded → enter it through the hub (spawn-and-return), never execve.
    return hub(preselect=project)


def status() -> int:
    # Cold-start discipline: heavy imports (rich) only on demand.
    from products.dashboard.app import build_summary, render
    from rich.console import Console

    metrics = Path.home() / ".kinox" / "broker-events.jsonl"
    if not metrics.exists():
        print(f"kx status: no metrics yet at {metrics}")
        return 0
    Console().print(render(build_summary(metrics)))
    return 0


def activate(name: str) -> int:
    repo_root = Path(__file__).resolve().parent
    if name in RESERVED:
        # `kin` is the admin/core scope — open the launcher hub as admin
        # rather than bypassing it straight to a kinox session.
        # `kx new kin` is still jailed.
        return hub(role="admin")
    project = repo_root / "projects" / name
    if not project.is_dir():
        print(f"kx {name!r}: no such project — scaffold it with: kx new {name}")
        return 2
    # Activate an existing project → enter it through the hub (spawn-and-return).
    return hub(preselect=project)


def session_cmd() -> int:
    """Launch a governed kinox chat session (called by ``kin session``).

    Uses ``KIN_SCOPE_DIR`` to pick the working directory (default: repo root).
    Hands off to the chat TUI — when you ``/quit``, control returns to the
    caller (``kin``, which the hub spawned).
    """
    from kernel.manifest import probe
    from kernel.metrics import MetricsSink
    from products.chat.app import chat_run

    repo_root = Path(__file__).resolve().parent
    scope = Path(os.environ.get("KIN_SCOPE_DIR", str(repo_root)))
    return chat_run(
        manifest=probe(),
        sink=MetricsSink(Path.home() / ".kinox" / "chat-events.jsonl"),
        cwd=scope,
    )


def main(argv: list[str]) -> int:
    if not argv:
        return hub()  # bare `kx` → the default working environment (the hub)
    cmd, *rest = argv
    if cmd == "doctor":
        return doctor()
    if cmd == "status":
        return status()
    if cmd == "update":
        return update_cmd()
    if cmd == "dev":
        return hub(role="developer")  # the hub as a developer (projects only)
    if cmd == "new":
        if not rest:
            print("usage: kx new <project>")
            return 2
        return new(rest[0])
    if cmd == "session":
        return session_cmd()
    if cmd == "broker":
        return broker_cmd(rest)
    return activate(cmd)


if __name__ == "__main__":
    _load_env()  # secrets from ~/.kinox/env (e.g. ZAI_API_KEY) → os.environ
    _ensure_venv()  # ensure outer-layer deps (rich/questionary) are importable
    raise SystemExit(main(sys.argv[1:]))