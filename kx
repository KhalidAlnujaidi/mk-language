#!/usr/bin/env python3
"""kx — the kinox entrypoint.

Three laws (vision §8.2, braindump):
  kx                 → banner + interactive menu
  kx doctor          → health check
  kx new <project>   → scaffold a project under projects/<name>/
  kx <project>       → activate an existing project's framework

`kin` is the reserved admin/core scope — blacklisted as a project name and
hard-rejected at every entry point (the "keyword jail").

Cold-start discipline: no heavy imports, no config processing on bare `kx`.
This is a stub. Subcommands print intent and exit 0 until M0 wires them up.
"""

import sys

RESERVED = {"kin"}
BANNER = r"""
  _    _
 | | _(_)_ __   _____  __
 | |/ / | '_ \ / _ \ \/ /   local-first · governed · cost-efficient
 |   <| | | | | (_) >  <    workspace for coding agents
 |_|\_\_|_| |_|\___/_/\_\
"""


def _reject_reserved(name: str) -> None:
    if name in RESERVED:
        print(f"error: '{name}' is the reserved admin/core scope — not a project name.")
        sys.exit(2)


def menu() -> int:
    print(BANNER)
    print("  kx doctor          health check")
    print("  kx status          observability dashboard")
    print("  kx new <project>   scaffold a new project")
    print("  kx <project>       activate an existing project")
    print()
    print("  (stub — subcommands are wired up incrementally; see vision.md §8)")
    return 0


def doctor() -> int:
    # Cold-start discipline: import kernel modules inside the function body.
    from kernel.manifest import probe

    m = probe()

    def _fmt(val: object) -> str:
        return str(val) if val is not None else "unknown"

    fitting = m.fitting_local_models()
    fitting_str = ", ".join(model.name for model in fitting) if fitting else "none"
    cloud_str = "yes" if m.cloud_available else "no"

    print("kx doctor — system health")
    print(f"  cpu:                  {_fmt(m.cpu_count)}")
    print(f"  ram (gb):             {_fmt(m.ram_gb)}")
    print(f"  gpu vram (gb):        {_fmt(m.gpu_vram_gb)}")
    print(f"  fitting local models: {fitting_str}")
    print(f"  cloud:                {cloud_str}")

    # Reconciliation: expected-vs-runtime drift (no persisted baseline yet, so
    # expected == present → healthy; protected-file checksums wire in later).
    from daemon.doctor import diagnose
    from products.cli.commands import format_doctor_findings

    present = {model.name for model in m.local_models}
    findings = diagnose(expected_models=present, present_models=present)
    print(format_doctor_findings(findings))
    return 0


def new(name: str) -> int:
    _reject_reserved(name)
    # Cold-start discipline: import inside the function body.
    from pathlib import Path

    from products.cli.commands import scaffold_project

    repo_root = Path(__file__).resolve().parent
    project = scaffold_project(repo_root / "projects", name)
    print(str(project / "next.md"))
    return 0


def status() -> int:
    # Cold-start discipline: heavy imports (rich) only on demand.
    from pathlib import Path

    from rich.console import Console

    from products.dashboard.app import build_summary, render

    metrics = Path.home() / ".kinox" / "broker-events.jsonl"
    if not metrics.exists():
        print(f"kx status: no metrics yet at {metrics}")
        return 0
    Console().print(render(build_summary(metrics)))
    return 0


def activate(name: str) -> int:
    _reject_reserved(name)
    print(f"kx {name!r}: stub — will activate the project framework.")
    return 0


def main(argv: list[str]) -> int:
    if not argv:
        return menu()
    cmd, *rest = argv
    if cmd == "doctor":
        return doctor()
    if cmd == "status":
        return status()
    if cmd == "new":
        if not rest:
            print("usage: kx new <project>")
            return 2
        return new(rest[0])
    return activate(cmd)


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
